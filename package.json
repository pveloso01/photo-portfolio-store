{
  "name": "photo-portfolio-store",
  "version": "0.1.0",
  "private": true,
  "description": "Photographer portfolio + print storefront with face-recognition search",
  "engines": {
    "node": ">=20.18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome check --apply .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "turbo run test",
    "test:integration": "pnpm -r --filter @app/api --filter @app/worker test:integration",
    "test:integration:up": "docker compose -f docker-compose.dev.yml up -d postgres minio",
    "seed": "pnpm --filter @app/api tsx scripts/seed.ts",
    "py:dev": "cd apps/inference && uv run uvicorn app.main:app --reload --port 8000",
    "py:test": "cd apps/inference && uv run pytest",
    "py:lint": "cd apps/inference && uv run ruff check .",
    "py:format": "cd apps/inference && uv run ruff format .",
    "codegen": "pnpm --filter @pkg/api-types codegen",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "lint-staged": "^15.2.10",
    "simple-git-hooks": "^2.11.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec biome check --diagnostic-level=error .",
    "commit-msg": "pnpm exec commitlint --edit $1"
  }
}
