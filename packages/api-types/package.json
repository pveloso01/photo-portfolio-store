{
  "name": "@pkg/api-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src",
    "codegen": "openapi-typescript ../../openapi.yaml -o src/generated.ts",
    "codegen:check": "node scripts/check-drift.mjs"
  },
  "devDependencies": {
    "@pkg/tsconfig": "workspace:*",
    "@types/node": "^22.10.1",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.2"
  }
}
