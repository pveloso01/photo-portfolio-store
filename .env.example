# Canonical list of environment variables for photo-portfolio-store.
#
# This file IS committed. It documents every variable any service may read.
# Real secrets live in Doppler (see docs/adr/0003-secrets.md).
#
# Local development: copy to .env.local (gitignored) and fill in values,
# or use `doppler run -- pnpm dev` to inject them automatically.

# --- Core ---
# Runtime environment: development | production | test
NODE_ENV=development
# Log verbosity: debug | info | warn | error
LOG_LEVEL=debug
# Public-facing app URL (used in emails, redirects, OG tags)
APP_BASE_URL=http://localhost:3000
# Internal API base URL
API_BASE_URL=http://localhost:4000
# Port the API listens on
PORT=4000

# --- Database ---
# Postgres connection string
DATABASE_URL=postgres://photo:photo@localhost:5432/photo
# Redis connection (queue + cache)
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# JWT signing secret for access tokens (>=32 chars random)
JWT_ACCESS_SECRET=replace-with-32-plus-char-random-string
# JWT signing secret for refresh tokens (>=32 chars random, distinct from access)
JWT_REFRESH_SECRET=replace-with-different-32-plus-char-random-string
# Access token lifetime
JWT_ACCESS_TTL=15m
# Refresh token lifetime
JWT_REFRESH_TTL=30d
# argon2id memory cost in KiB (default ~19 MiB is OWASP recommended)
ARGON2_MEMORY_KIB=19456

# --- Object storage (R2 / S3-compatible) ---
# S3 endpoint URL (leave empty to use default AWS endpoint; for R2 use https://<account>.r2.cloudflarestorage.com; for local MinIO use http://localhost:9000)
S3_ENDPOINT=http://localhost:9000
# S3 region (use `auto` for R2)
S3_REGION=auto
# Access key for S3 / R2 / MinIO
S3_ACCESS_KEY_ID=minioadmin
# Secret key for S3 / R2 / MinIO
S3_SECRET_ACCESS_KEY=minioadmin
# Bucket holding original uploaded photos (private)
S3_BUCKET_ORIGINALS=photo-originals
# Bucket holding derivatives (thumb, preview, web) served via CDN
S3_BUCKET_DERIVATIVES=photo-derivatives
# Public CDN base URL for derivatives (Cloudflare-fronted)
S3_PUBLIC_BASE_URL=http://localhost:9000/photo-derivatives

# --- Vector DB (Qdrant) ---
# Qdrant HTTP endpoint
QDRANT_URL=http://localhost:6333
# Qdrant API key (optional for self-hosted dev)
QDRANT_API_KEY=

# --- Inference service ---
# URL of the Python FastAPI inference service
INFERENCE_URL=http://localhost:8000
# Shared secret between API and inference service for HMAC auth
INFERENCE_API_KEY=replace-with-shared-secret

# --- Stripe ---
# Stripe secret key (test mode prefix: sk_test_)
STRIPE_SECRET_KEY=sk_test_replace_me
# Webhook signing secret from Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Stripe Connect platform client id (for photographer onboarding)
STRIPE_CONNECT_CLIENT_ID=ca_replace_me

# --- Email ---
# Resend API key (production); leave blank locally to use SMTP_URL via Mailhog
RESEND_API_KEY=
# SMTP URL fallback (Mailhog local: smtp://localhost:1025)
SMTP_URL=smtp://localhost:1025
# From address for transactional email
EMAIL_FROM="Photos <no-reply@example.com>"

# --- Observability ---
# Sentry DSN — leave blank locally so Sentry init is a no-op
SENTRY_DSN=
# OpenTelemetry collector endpoint (Jaeger/SigNoz local container)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTel service name — set per service (api | worker | inference)
OTEL_SERVICE_NAME=api

# --- Feature flags / safety ---
# Default retention window for face vectors after event ends
BIOMETRIC_RETENTION_DAYS_DEFAULT=30
# Auth endpoint rate limit per IP per minute
RATE_LIMIT_AUTH_REQS_PER_MIN=10
