    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@sentry/node": "^8.45.0",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.36.4",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.0",
    "postgres": "^3.4.5",
    "@opentelemetry/sdk-node": "^0.55.0",
